{
  "expo": {
    "name": "Quitter",
    "slug": "Quitter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0df2a6",
          "defaultChannel": "streak-reminders",
          "sounds": []
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "googleExpoClientId": "",
      "googleIosClientId": "",
      "googleAndroidClientId": "",
      "googleWebClientId": ""
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
